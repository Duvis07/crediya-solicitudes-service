# Database Configuration
R2DBC_HOST=localhost
#R2DBC_PORT=5434
R2DBC_PORT=5433
R2DBC_DATABASE=crediya_solicitudes_db
R2DBC_USERNAME=postgres
R2DBC_PASSWORD=nueva_password

# Authentication Service Configuration
AUTH_SERVICE_BASE_URL=http://localhost:8080
AUTH_SERVICE_ENDPOINTS_API_BASE=/api/v1/usuarios
AUTH_SERVICE_ENDPOINTS_USER_BY_DOCUMENT=/{documentId}

# JWT Configuration
JWT_JWK_SET_URI=http://localhost:8080/.well-known/jwks.json
JWT_ISSUER_URI=http://localhost:8080
JWT_SECRET=mySecretKeyForCrediyaAuthenticationServiceThatIsLongEnoughForHS256

# AWS LocalStack Configuration
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SQS_ENDPOINT=http://localhost:4566
AWS_SQS_QUEUES_SOLICITUDES_CAPACIDAD=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/solicitudes-capacidad-queue
AWS_SQS_QUEUES_RESULTADOS_EVALUACION=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/resultados-evaluacion-queue
AWS_SQS_QUEUES_MANUAL_DECISION=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/notificaciones-manuales-queue
AWS_SQS_QUEUES_LOAN_APPROVED_EVENTS=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/loan-approved-events-queue

# Email Configuration
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
MAILHOG_WEB_URL=http://localhost:8025

# Spring Configuration
SPRING_PROFILES_ACTIVE=local
