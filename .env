# Database Configuration
R2DBC_HOST=localhost
R2DBC_PORT=5433
R2DBC_DATABASE=crediya_solicitudes_db
R2DBC_USERNAME=postgres
R2DBC_PASSWORD=nueva_contraseña

# Authentication Service Configuration
AUTH_SERVICE_URL=http://localhost:8080
AUTH_SERVICE_API_BASE=/api/v1
AUTH_SERVICE_USERS_BASE=/api/v1/usuarios
AUTH_SERVICE_USER_BY_DOCUMENT=/api/v1/usuarios/{documentId}

# JWT Configuration
JWT_JWK_SET_URI=http://localhost:8080/.well-known/jwks.json
JWT_ISSUER_URI=http://localhost:8080

# Spring Configuration
SPRING_PROFILES_ACTIVE=local
